# Copy to .env and fill in your values
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=sb_publishable_your_key
SUPABASE_SECRET_KEY=sb_secret_your_key
SUPABASE_TABLE=do11y_integration_test

# Required for test-queries.ts (direct Postgres connection)
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Optional: comma-separated subset (default: all)
# FRAMEWORKS=mintlify,docusaurus,nextra,vitepress,mkdocs-material

# Optional: skip npm/pip install on repeat runs
# SKIP_INSTALL=1
