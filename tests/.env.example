# Copy to .env and fill in your values
TINYBIRD_HOST=api.tinybird.co
TINYBIRD_TOKEN=your-token
TINYBIRD_DATASOURCE=do11y-integration-test

# Optional: comma-separated subset (default: all)
# FRAMEWORKS=mintlify,gitbook,docusaurus,nextra,vitepress,mkdocs-material

# Optional: skip npm/pip install on repeat runs
# SKIP_INSTALL=1
